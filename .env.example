# Copy to .env and adjust. All values are local-only; nothing here is sent to the cloud.

# Where the local ChromaDB vector store lives
CHROMA_PATH=./.chroma
CHROMA_COLLECTION=clinical_manual

# Local Ollama endpoint (embeddings + generation). Zero data egress.
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.1:8b

# Retrieval tuning
TOP_K=8          # candidates pulled from the vector store
FINAL_K=4        # candidates kept after re-ranking and handed to the LLM
MIN_SCORE=0.15   # below this top score, the assistant refuses instead of guessing

# Set to 1 to run fully offline (deterministic hash embedder, no Ollama needed).
# Used by `ask.py selftest` and CI. Not for production-quality answers.
OFFLINE_EMBEDDINGS=0
